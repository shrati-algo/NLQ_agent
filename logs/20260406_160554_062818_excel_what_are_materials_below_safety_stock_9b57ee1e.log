{"timestamp": "2026-04-06T16:05:54.078", "step": "excel_followup_context", "status": "info", "payload": {"selected_table": "dummy_current_inventory2", "sql_executed": "SELECT \n    plant, \n    material, \n    material_name, \n    material_type, \n    uom, \n    shelf_stock, \n    git, \n    wip, \n    doh, \n    safety_stock, \n    demand, \n    product_family, \n    sop_family, \n    product_group, \n    material_group, \n    product_category, \n    material_application, \n    sub_application, \n    abc, \n    mrp_controller_text, \n    purchasing_group_text, \n    (shelf_stock + git + wip) AS total_stock, \n    ((shelf_stock + git + wip) - safety_stock) AS stock_gap_vs_safety, \n    CASE WHEN demand = 0 THEN 0 ELSE (shelf_stock + git + wip) / NULLIF(demand, 0) END AS coverage_ratio, \n    CASE \n        WHEN (shelf_stock + git + wip) < safety_stock THEN 'Below Safety' \n        WHEN (shelf_stock + git + wip) / NULLIF(demand, 0) < 1 THEN 'Tight' \n        ELSE 'Healthy' \n    END AS inventory_health, \n    CASE \n        WHEN demand > 0 AND (shelf_stock + git + wip) < demand THEN 'High' \n        ELSE 'Normal' \n    END AS demand_risk_flag, \n    (shelf_stock + git + wip) AS estimated_value_proxy \nFROM \n    dummy_current_inventory2 \nLIMIT 10;", "row_count": 10}}
